# Discord bot tokens (one for each bot)
BOT_TOKEN_0=your_bot_token_1
BOT_TOKEN_1=your_bot_token_2
BOT_TOKEN_2=your_bot_token_3
BOT_TOKEN_3=your_bot_token_4
BOT_TOKEN_4=your_bot_token_5
BOT_TOKEN_5=your_bot_token_6
BOT_TOKEN_6=your_bot_token_7
BOT_TOKEN_7=your_bot_token_8
BOT_TOKEN_8=your_bot_token_9
BOT_TOKEN_9=your_bot_token_10

NODE_ENV=production

# Optional runtime tuning for low-resource hosts (Render, etc.)
# Delay between starting each bot process in milliseconds
BOT_START_DELAY_MS=5000

# Base and max restart delay for crashed bot processes (milliseconds)
BOT_RESTART_DELAY_MS=5000
BOT_MAX_RESTART_DELAY_MS=60000

# Discord login timeout per bot process (milliseconds)
BOT_LOGIN_TIMEOUT_MS=90000
